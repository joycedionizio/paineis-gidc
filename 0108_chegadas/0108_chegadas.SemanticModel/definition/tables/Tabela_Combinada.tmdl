table Tabela_Combinada
	lineageTag: 77a54efd-ad80-419f-8772-9af55f86e8ed

	column ano
		dataType: int64
		formatString: 0
		lineageTag: a84919ca-74f0-4600-8a18-ef22b148b114
		summarizeBy: sum
		isNameInferred
		sourceColumn: [ano]

		annotation SummarizationSetBy = Automatic

	column valor
		dataType: int64
		formatString: #,0
		lineageTag: 80a6a0c2-4bca-474b-a18f-6a6766dfe982
		summarizeBy: sum
		isNameInferred
		sourceColumn: [valor]

		annotation SummarizationSetBy = Automatic

	column tipo
		lineageTag: 8721cb8b-5286-4698-b8cd-50b9dc27f30d
		summarizeBy: none
		isNameInferred
		sourceColumn: [tipo]

		annotation SummarizationSetBy = Automatic

	column fonte
		lineageTag: ed390bc0-ca12-4e27-8b46-843910d8045f
		summarizeBy: none
		isNameInferred
		sourceColumn: [fonte]

		annotation SummarizationSetBy = Automatic

	column ano_ordenado = INT('Tabela_Combinada'[ano])
		formatString: 0
		lineageTag: 62770c74-f237-4186-be64-723c26ed7846
		summarizeBy: sum
		sortByColumn: ano

		annotation SummarizationSetBy = Automatic

	partition Tabela_Combinada = calculated
		mode: import
		source =
				
				VAR Chegadas2024 =
				    SUMMARIZE(
				        FILTER('dbmtur chegadas_2013_2023', 'dbmtur chegadas_2013_2023'[ano] = 2024),
				        'dbmtur chegadas_2013_2023'[ano],
				        "valor", SUM('dbmtur chegadas_2013_2023'[total_chegadas]),
				        "tipo", "Real",
				        "fonte", "Total de Chegadas de 2024"
				    )
				
				VAR Chegadas2025 =
				    SUMMARIZE(
				        FILTER('dbmtur chegadas_2013_2023', 'dbmtur chegadas_2013_2023'[ano] = 2025),
				        'dbmtur chegadas_2013_2023'[ano],
				        "valor", SUM('dbmtur chegadas_2013_2023'[total_chegadas]),
				        "tipo", "Real",
				        "fonte", "Total de Chegadas de 2025"
				    )
				
				RETURN
				    UNION(
				        SELECTCOLUMNS(
				            'Projecao Chegadas',
				            "ano", 'Projecao Chegadas'[ano],
				            "valor", 'Projecao Chegadas'[estimativa],
				            "tipo", "Estimativa",
				            "fonte", 'Projecao Chegadas'[fonte]
				        ),
				        Chegadas2024,
				        Chegadas2025
				    )

	annotation PBI_Id = 33730d2c346d4ddfb43580cb5a1593c1

