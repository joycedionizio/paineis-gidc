table Medidas
	lineageTag: b4e86833-e9c8-4e2b-a046-21c928345eec

	measure TotalChegadas2023 =
			
			CALCULATE (
			    SUM (Historico[total]),
			    Historico[ano] = 2023
			)
		formatString: 0
		lineageTag: e34b29ca-0095-48a8-8f37-e54729650579

	measure 'Est 2024 Chegadas Global' =
			
			CALCULATE (
			    SUM('Projecao Chegadas'[estimativa]), 'Projecao Chegadas'[ano]=2024,
			    'Projecao Chegadas'[fonte] = "Globaldata"
			)
		formatString: 0
		lineageTag: 1dfe0485-e6a1-4af4-8ef2-63cbba96a6c9

	measure 'Est 2024 Chegadas Oxford' =
			
			CALCULATE (
			    SUM('Projecao Chegadas'[estimativa]), 'Projecao Chegadas'[ano]=2024,
			    'Projecao Chegadas'[fonte] = "Oxford"
			)
		formatString: 0
		lineageTag: f8920960-fa67-43e2-b36e-4d1e42132e0a

	measure TaxaCrescimento2023_2024Global = ```
			
			DIVIDE (
			    [Est 2024 Chegadas Global] - [Chegadas2024],
			    [Chegadas2024],
			    0
			) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: e8a97ac2-9bc2-4968-96c2-f3b40b0847d2

	measure Chegadas2024 =
			
			CALCULATE (
			    SUM (Historico[total]),
			    Historico[ano] = 2024
			)
		formatString: #,0
		lineageTag: df7f7d7a-4aa2-463d-a6a2-e4ce196cf755

	measure TaxaCrescimento2023_2024Oxford = ```
			
			DIVIDE (
			    [Est 2024 Chegadas Oxford] - [Chegadas2024],
			    [Chegadas2024],
			    0
			) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: b20b6210-d6ba-4bf1-9413-cecb952372ea

	measure 'Chegadas Mes Corrente Ano Anterior' = ```
			
			VAR AnoMaisRecente = MAX('dbmtur chegadas_2013_2023'[ano])
			VAR MesMaisRecente = CALCULATE(MAX('dbmtur chegadas_2013_2023'[mes]), 'dbmtur chegadas_2013_2023'[ano] = AnoMaisRecente)
			VAR AnoAnterior = AnoMaisRecente - 1
			RETURN
			SUMX(
			    FILTER(
			        'dbmtur chegadas_2013_2023', 
			        'dbmtur chegadas_2013_2023'[ano] = AnoAnterior && 'dbmtur chegadas_2013_2023'[mes] = MesMaisRecente
			    ), 
			    'dbmtur chegadas_2013_2023'[total_chegadas]
			)
			```
		formatString: #,0
		lineageTag: 162fba54-948d-4b75-8a7c-c9fcd400e2ef

	measure 'Chegadas Mes Atual' = ```
			
			VAR AnoMaisRecente = MAX('dbmtur chegadas_2013_2023'[ano])
			VAR MesMaisRecente = CALCULATE(MAX('dbmtur chegadas_2013_2023'[mes]), 'dbmtur chegadas_2013_2023'[ano] = AnoMaisRecente)
			RETURN
			SUMX(
			    FILTER(
			        'dbmtur chegadas_2013_2023', 
			        'dbmtur chegadas_2013_2023'[ano] = AnoMaisRecente && 'dbmtur chegadas_2013_2023'[mes] = MesMaisRecente
			    ), 
			    'dbmtur chegadas_2013_2023'[total_chegadas]
			)
			```
		formatString: #,0
		lineageTag: f20620c9-b2d7-4518-bc5f-ee513935ba4f

	measure ChegadasAteMesAtual =
			VAR UltimoMes = [UltimoMesDisponivel2024]
			RETURN
			CALCULATE(
			    SUM('dbmtur chegadas_2013_2023'[total_chegadas]),
			    'dbmtur chegadas_2013_2023'[ano] = 2026,
			    'dbmtur chegadas_2013_2023'[mes] <= UltimoMes
			)
		formatString: #,0
		lineageTag: b9fb29d2-7760-44e0-b387-1da5ee5377cb

	measure MesAtual2024 =
			
			CALCULATE (
			    MAX ('dbmtur chegadas_2013_2023'[mes]),
			    'dbmtur chegadas_2013_2023'[ano] = 2024
			)
		formatString: 0
		lineageTag: 8b6e847b-8607-44e2-b793-eedbb8c64f7a

	measure 'Variação Mes Atual Anterior' = Medidas[Chegadas Mes Atual] - Medidas[Chegadas Mes Corrente Ano Anterior]
		formatString: #,0
		lineageTag: d721d4e7-351d-4161-9519-07b76ffee032

	measure 'Percentual de Variação Mes Atual' = ```
			
			DIVIDE(
			     Medidas[Variação Mes Atual Anterior], 
			     Medidas[Chegadas Mes Corrente Ano Anterior],
			    0
			)
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 487a0f1b-eee0-481a-a406-58e15e322c2c

	measure 'Est 2024 Chegadas Plano Nacional' =
			
			CALCULATE (
			    SUM('Projecao Chegadas'[estimativa]), 'Projecao Chegadas'[ano]=2024,
			    'Projecao Chegadas'[fonte] = "Plano Nacional do Turismo"
			)
		formatString: 0
		lineageTag: d7d759ae-0590-4ba1-9eae-fe7469112287

	measure TaxaCrescimento2023_2024PNT = ```
			
			DIVIDE (
			    [Est 2024 Chegadas Plano Nacional] - [Chegadas2024],
			    [Chegadas2024],
			    0
			) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 591e3720-01f8-4d7f-8188-268dfee64a4e

	measure 'Total de Chegadas Ano Corrente' =
			
			CALCULATE(
			    SUM('dbmtur chegadas_2013_2023'[total_chegadas]),
			    'dbmtur chegadas_2013_2023'[ano] = 2024
			)
		formatString: #,0
		lineageTag: 2335f421-3176-4c2c-aa7e-d189fe6e3f39

	measure 'Total de Chegadas Ano Anterior' =
			
			VAR Meses2024 = VALUES('dbmtur chegadas_2013_2023'[mes])
			RETURN
			CALCULATE(
			    SUM('dbmtur chegadas_2013_2023'[total_chegadas]),
			    FILTER(
			        ALL('dbmtur chegadas_2013_2023'),
			        'dbmtur chegadas_2013_2023'[ano] = 2023 &&
			        'dbmtur chegadas_2013_2023'[mes] IN Meses2024
			    )
			)
		formatString: 0
		lineageTag: 6828888c-18a9-4475-98be-016120eb945f

	measure 'Variação de Chegadas' = [Total de Chegadas Ano Corrente] - [Total de Chegadas Ano Anterior]
		formatString: 0
		lineageTag: 74bfd5ee-4a4d-4f37-b510-2a46bebbedea

	measure 'Total Chegadas 1970' = SUM(Historico[total])
		formatString: #,0
		lineageTag: 50b3b52c-3cd1-49b6-8d80-ad3a42eeaeb3

	measure 'Total Chegadas' = Medidas[Total Chegadas 1970] + Medidas[Chegadas Mes Atual]
		formatString: #,0
		lineageTag: a603db86-bdea-420e-ad66-6cf4425e1dec

	measure 'Melhor Ano' = ```
			
			VAR MelhorAno = 
			    CALCULATE(
			        MAXX(
			            TOPN(1, 'Historico', 'Historico'[total], DESC),
			            'Historico'[ano]
			        )
			    )
			RETURN
			FORMAT(MelhorAno, "0")
			```
		lineageTag: 5b04af3d-1340-4714-95b3-4d7f0a47c19d

	measure 'Total do Melhor Ano' =
			
			CALCULATE(
			    MAX('Historico'[total]
			))
		formatString: #,0
		lineageTag: 06505014-e277-4514-8566-20c5b1774f85

	measure 'Total Aerea' =
			
			CALCULATE (
			    SUM('dbmtur chegadas_2013_2023'[total_chegadas]),
			    'dbmtur chegadas_2013_2023'[via_de_acesso]="Aérea"
			)
		formatString: #,0
		lineageTag: 17954961-4565-4e94-af3e-7275f06e4677

