			    'dbmtur chegadas_2013_2023'[via_de_acesso]="Marítima"
			)
		formatString: #,0
		lineageTag: efc266c3-c336-4917-bb29-e31a0296782b

	measure 'Total Fluvial' =
			
			CALCULATE (
			    SUM('dbmtur chegadas_2013_2023'[total_chegadas]),
			    'dbmtur chegadas_2013_2023'[via_de_acesso]="Fluvial"
			)
		formatString: #,0
		lineageTag: 25b8846f-24f3-44c7-9e6f-f405a060d985

	measure UltimoMesDisponivel2024 =
			
			CALCULATE(
			    MAX('dbmtur chegadas_2013_2023'[mes]),
			    'dbmtur chegadas_2013_2023'[ano] = 2024,
			    REMOVEFILTERS('dbmtur chegadas_2013_2023'[mes])
			)
		lineageTag: d8e91712-6e0d-47d5-8213-f334e4cc1c47

	measure ParcialSomaChegadas2023 =
			
			VAR UltimoMes2024 = MONTH([UltimoMesDisponivel2024])
			RETURN
			CALCULATE(
			    SUM('dbmtur chegadas_2013_2023'[total_chegadas]),
			    'dbmtur chegadas_2013_2023'[ano] = 2023,
			    'dbmtur chegadas_2013_2023'[mes] <= UltimoMes2024
			)
		formatString: #,0
		lineageTag: 87886428-6474-4993-af4f-50c0eea1da19

	measure Variacao2024_2025 = Medidas[ChegadasAteMesAtual] - Medidas[ChegadasAteUltimoMes2024]
		formatString: #,0
		lineageTag: 6f406fe5-310b-48b5-980b-f744372cb727

	measure ChegadasAteUltimoMes2024 =
			
			CALCULATE(
			    SUM('dbmtur chegadas_2013_2023'[total_chegadas]),
			    'dbmtur chegadas_2013_2023'[ano] = 2025,
			    'dbmtur chegadas_2013_2023'[mes] <= 5
			)
		formatString: #,0
		lineageTag: 361c4b9e-ab57-4a23-bfc6-f7ed00dae608

	measure 'Percentual Variação 2024 2025' = ```
			
			DIVIDE(
			     Medidas[Variacao2024_2025], 
			     Medidas[ChegadasAteUltimoMes2024],
			    0
			)
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: a249e8d1-b851-4d83-83ff-9c8fe6d5170e

