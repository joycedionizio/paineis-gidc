	measure TotalChegadas2023Geral =
			
			CALCULATE (
			    SUM ('dbmtur chegadas_2013_2023'[total_chegadas]),
			    'dbmtur chegadas_2013_2023'[ano] = 2023
			)
		formatString: #,0
		lineageTag: 3fcddd17-8684-4a1f-841c-b9669121915e

	measure TotalChegadas2024Geral =
			
			CALCULATE (
			    SUM ('dbmtur chegadas_2013_2023'[total_chegadas]),
			    'dbmtur chegadas_2013_2023'[ano] = 2024
			)
		formatString: #,0
		lineageTag: 7ee809ab-ba1f-4ee6-bb21-8bad305a132b

	measure PercentualCrescimento23-24 =
			
			DIVIDE(
			    [TotalChegadas2024Geral] - [TotalChegadas2023Geral],
			    [TotalChegadas2023Geral]
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 085abcdb-1af7-47a2-bf01-b4a84d936f02

	partition Medidas = m
		mode: import
		source =
				let
				    Fonte = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [#"Coluna 1" = _t]),
				    #"Tipo Alterado" = Table.TransformColumnTypes(Fonte,{{"Coluna 1", type text}}),
				    #"Colunas Removidas" = Table.RemoveColumns(#"Tipo Alterado",{"Coluna 1"})
				in
				    #"Colunas Removidas"

	annotation PBI_ResultType = Table

