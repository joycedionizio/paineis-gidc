	partition Calendario = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS(
				    CALENDARAUTO(),
				    "Ano", YEAR( [Date] ),
				    "Mês", MONTH( [Date] ),
				    "Mês Abr", FORMAT( [Date], "mmm" ),
				    "Mês Nome", FORMAT([Date], "mmmm" ), 
				    "Data chegadas",  [Date] <= MAX('dbmtur chegadas_2013_2023'[data] )
				)
				```

