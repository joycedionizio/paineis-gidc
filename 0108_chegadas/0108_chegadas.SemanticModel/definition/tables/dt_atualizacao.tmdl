table dt_atualizacao
	lineageTag: d55d8505-bade-460f-b407-10e322e6fb10

	measure 'Texto Atualizacao' = ```
			
			"Data de atualização: " & 
			FORMAT(MAX('dt_atualizacao'[data_atualizacao]), "dd") & " de " & 
			FORMAT(MAX('dt_atualizacao'[data_atualizacao]), "MMMM") & " de " & 
			FORMAT(MAX('dt_atualizacao'[data_atualizacao]), "yyyy")
			```
		lineageTag: d59ff783-b643-42a1-a47c-d5c630c0a2bd

	column data_atualizacao
		dataType: dateTime
		formatString: General Date
		lineageTag: 784ebadb-d46f-4b75-bb3b-c67ba5806148
