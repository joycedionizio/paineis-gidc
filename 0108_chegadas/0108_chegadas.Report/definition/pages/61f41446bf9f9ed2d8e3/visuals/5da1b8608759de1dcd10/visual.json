                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": "Este é o Dicionário de Dados do Painel de Chegadas da Embratur.",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": "1. Emissor",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "País de origem do turista. Em caso de estrangeiros, é a sua ",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  },
                  {
                    "value": "nacionalidade",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  },
                  {
                    "value": ", em caso de brasileiros, o seu ",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  },
                  {
                    "value": "país de residência",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  },
                  {
                    "value": ".",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": "2. Portão de entrada",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "É o local pelo qual o turista acessou o país.",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": "3. Turista",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Um visitante (doméstico, nacional ou internacional) é classificado como turista se a sua viagem incluir uma pernoite. ",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": "4. Turista internacional",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "O conceito de turista internacional parte da junção do número de turistas estrangeiros com os turistas brasileiros que moram no exterior e visitam o Brasil.",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": "5. Via de acesso",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "São as formas de chegada do viajante ao país, elas se dividem em:",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "a. Aérea",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "b. Fluvial",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#e6605b"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
